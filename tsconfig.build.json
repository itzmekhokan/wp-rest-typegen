{
	"extends": "./tsconfig.json",
	"compilerOptions": {
		"noEmit": false,
		"declaration": true,
		"declarationMap": true,
		"sourceMap": true,
		"outDir": "dist",
		"rootDir": "src",
		"rewriteRelativeImportExtensions": true
	},
	"include": ["src/**/*.ts"],
	"exclude": ["tests", "node_modules", "dist"]
}
