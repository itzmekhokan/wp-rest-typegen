{
	"name": "wp-rest-typegen",
	"version": "0.1.2",
	"description": "Generate TypeScript types from a live WordPress REST API — core endpoints plus custom post types, fields, and taxonomies. Zero dependencies.",
	"keywords": [
		"wordpress",
		"rest-api",
		"typescript",
		"codegen",
		"types",
		"gutenberg"
	],
	"type": "module",
	"bin": {
		"wp-rest-typegen": "dist/cli.js"
	},
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		},
		"./package.json": "./package.json"
	},
	"files": [
		"dist",
		"README.md",
		"CHANGELOG.md"
	],
	"scripts": {
		"build": "rm -rf dist && tsc -p tsconfig.build.json",
		"demo": "node src/cli.ts --input fixtures/post-schema.json --context edit",
		"test": "node --test 'tests/*.test.ts'",
		"typecheck": "tsc --noEmit",
		"prepublishOnly": "npm run build && npm test"
	},
	"engines": {
		"node": ">=20.16.0"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/itzmekhokan/wp-rest-typegen.git"
	},
	"homepage": "https://itzmekhokan.github.io/wp-rest-typegen/",
	"bugs": {
		"url": "https://github.com/itzmekhokan/wp-rest-typegen/issues"
	},
	"license": "GPL-2.0-or-later",
	"author": "Khokan Sardar",
	"dependencies": {},
	"devDependencies": {
		"@types/node": "^22.0.0",
		"typescript": "^5.7.0"
	}
}
